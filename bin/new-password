#!/usr/bin/env python3
import secrets
import string
import argparse

alphabet = (
    string.ascii_lowercase + string.ascii_uppercase + string.digits + string.punctuation
)

parser = argparse.ArgumentParser()
parser.add_argument("-n", metavar="LENGTH", type=int, default=100)
args = parser.parse_args()

print("".join(secrets.choice(alphabet) for _ in range(args.n)))
