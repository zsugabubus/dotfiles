	function M:parse_cli_args(args)
		local function parse_auth(s)
			return match(s, '^([^:]*):(.*)$')
		end

		local function parse_url(s)
			local protocol, host_port, path = match(s, '^(https?://)([^/]+)(.*)')

			if not protocol then
				host_port, path = match(s, '^([^/]+)(.*)')
			end

			if path == '' then
				path = nil
			end

			local host, port = match(host_port, '^(.+):(%d+)$')
			port = tonumber(port or host_port)

			if not port then
				host = host_port
			end

			return protocol, host, port, path
		end

		local prog = match(args[0], '[^/]*$')
		local username, password = parse_auth(os.getenv('TR_AUTH') or '')
		local url

		for _, s in ipairs(args) do
			if s == '-h' or s == '--help' then
				print(format(
					[[
Usage: %s [ HOST | PORT | HOST:PORT | http://HOST:PORT/PATH ]
ncurses transmission client]],
					prog
				))
				os.exit()
			elseif not match(s, '^-') and not url then
				url = TransmissionSession.make_url(parse_url(s))
			else
				io.stderr:write(format("%s: invalid option -- '%s'\n", prog, s))
				os.exit(1)
			end
		end

		return {
			rpc_username = username,
			rpc_password = password,
			rpc_url = url or TransmissionSession.make_url(),
		}
	end

