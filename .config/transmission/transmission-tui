	help('Select torrent using an external finder.')
	function M:select_torrent_fuzzy()
		local torrents = self._torrents.list

		local stdin = uv.new_pipe()
		local stdout = uv.new_pipe()
		local reply = ''

		self:spawn_shell('fzr', {
			args = { '--read0', '--print-index' },
			stdio = { stdin, stdout, 2 },
		}, function(err)
			if err then
				return
			end

			local index0 = match(reply, '^%d+\n$')
			if index0 then
				self._torrents:move_cursor(index0 + 1)
				return
			end

			local ids = {}

			for index0 in gmatch(reply, '%d+') do
				local torrent = torrents[index0 + 1]
				insert(ids, assert(torrent.hashString))
			end

			if #ids == 0 then
				return
			end

			self:set_torrent_filter_by_ids(ids)
		end)

		stdin:write(with_buffer(function(buf)
			for _, torrent in ipairs(torrents) do
				buf:put(torrent.name, '\0')
			end
		end))
		stdin:shutdown(function()
			stdin:close()
		end)

		stdout:read_start(function(_, data)
			if data then
				reply = reply .. data
			else
				stdout:close()
			end
		end)
	end

