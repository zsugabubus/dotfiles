	local function add_torrents(self, collect_torrent_files, delete_after_add)
		local function shesc(s)
			return "'" .. gsub(s, "'", [['"'"']]) .. "'"
		end

		local function b64file(path)
			local f = io.popen('base64 2>/dev/null -- ' .. shesc(path) .. ' && echo')
			local s = assert(f:read('*a'))
			assert(f:close())
			return s ~= '' and s or nil
		end

		local new_ids = {}

		local function callback()
			set_torrent_action_message(self, #new_ids, 'added')

			if #new_ids == 0 then
				return
			end

			update_session_stats(self)

			if #new_ids == 1 then
				update_torrents(self)
				for index, torrent in ipairs(self._torrents.list) do
					if torrent.hashString == new_ids[1] then
						self._torrents:move_cursor(index)
						return
					end
				end
			end

			self:set_torrent_filter_by_ids(new_ids)
		end

		local function prompt(initial_items)
			edit(self, {
				input = function(buf)
					for _, item in ipairs(initial_items) do
						if item.comment then
							buf:putf('# %s\n', esc(item.comment))
						end
						buf:putf('%s\n', esc(item.filename))
					end

					if #initial_items == 0 then
						buf:put('\n')

						local first = true
						for name in list_dir('.') do
							if find(name, '.torrent', -8, true) then
								if first then
									buf:put('\n')
									first = false
								end
								buf:putf('%s%s\n', collect_torrent_files and '' or '# ', name)
							end
						end
					end

					buf:put('\n')
					buf:putf(
						[[
# Add torrents.
#
# Place one item per line.%s
#
# Torrents added paused.
#
]],
						delete_after_add and ' Local files PERMANENTLY DELETED after add.' or ''
					)
				end,
			}, function(err, data)
				if err then
					if #new_ids == 0 then
						set_torrent_action_abort_message(self, 'added')
						return
					end
					callback()
					return
				end

				local errored_items = {}

				for s in parse_fields(data, '.+') do
					local output = b64file(s)

					local ok, payload = self.transmission:call_unchecked('torrent-add', {
						filename = not output and s or nil,
						metainfo = output,
						paused = true,
					})

					if ok then
						local new_torrent = payload['torrent-added'] or payload['torrent-duplicate']
						insert(new_ids, assert(new_torrent.hashString))
						if delete_after_add and output then
							os.remove(s)
						end
					else
						insert(errored_items, {
							filename = s,
							comment = format('Error: %s', payload),
						})
					end
				end

				if #errored_items > 0 then
					prompt(errored_items)
				else
					callback()
				end
			end)
		end

		prompt({})
	end

