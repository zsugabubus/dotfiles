local esc, unesc = (function()
	local ESC_TABLE = {
		['\n'] = '\\n',
		['\r'] = '\\r',
		['\t'] = '\\t',
		['\\'] = '\\\\',
	}

	local UNESC_TABLE = {
		['\\n'] = '\n',
		['\\r'] = '\r',
		['\\t'] = '\t',
		['\\\\'] = '\\',
	}

	local function esc(s)
		return (gsub(s, '[\n\r\t\\]', ESC_TABLE))
	end

	local function unesc(s)
		return (gsub(s, '\\.', UNESC_TABLE))
	end

	return esc, unesc
end)()

local KeyHandler = (function()
	local M = {}
	M.__index = M

	function M.new(cls)
		return setmetatable({}, cls)
	end

	function M:set_key_table(key_table)
		self._ground = key_table
		self._state = key_table
	end

	function M:push_key(key)
		local next_state = self._state[key]

		if next_state == nil then
			self._state = self._ground
			return nil
		end

		if type(next_state) == 'table' then
			self._state = next_state
			return nil
		end

		self._state = self._ground
		return next_state
	end

	return M
end)()

local function list_equal(a, b)
	if #a ~= #b then
		return false
	end
	for i = 1, #a do
		if a[i] ~= b[i] then
			return false
		end
	end
	return true
end

