local curs_width = (function()
	local win
	local win_cols = 0

	local mt = { __mode = 'kv' }
	local cache

	return function(s)
		local max_cols = curs.COLS
		if win_cols <= max_cols then
			cache = setmetatable({}, mt)
			if not win then
				win = Window.new(1, 1, 0, 0)
			end
			win_cols = max_cols + 1
			win:resize(1, win_cols)
		end
		local n = cache[s]
		if n ~= nil then
			return n
		end
		win:cursor(0, 0)
		win:put(s)
		n = min(max_cols, win:x())
		cache[s] = n
		return n
	end
end)()

