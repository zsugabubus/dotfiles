	help('Edit torrent trackers.')
	function M:show_torrent_trackers()
		local function tracker_stats_to_tracker_list(tracker_stats)
			local t = {}
			local current_tier
			for _, tracker in ipairs(tracker_stats) do
				if current_tier and current_tier ~= tracker.tier then
					insert(t, '')
				end
				current_tier = tracker.tier
				insert(t, assert(tracker.announce))
			end
			return t
		end

		local torrents = self:selected_torrents({ 'hashString', 'name', 'trackerStats' })

		local torrents_by_trackers = {}

		for index, torrent in ipairs(torrents) do
			local tracker_list = tracker_stats_to_tracker_list(torrent.trackerStats)
			local s = concat(tracker_list, '\n')

			torrents_by_trackers[s] = torrents_by_trackers[s] or {}
			insert(torrents_by_trackers[s], torrent)

			torrent.index = index
			torrent.trackerList = s
		end

		edit(self, {
			input = function(buf)
				for s, torrents in pairs(torrents_by_trackers) do
					for _, torrent in ipairs(torrents) do
						buf:putf('%d\t%s\n', torrent.index, esc(torrent.name))
					end
					buf:put('\n', s, '\n\n')
				end

				buf:putf([[
# Edit torrent trackers.
#
# Torrents followed by their trackers.
#
# Tiers are separated by a blank line.
#
]])
			end,
		}, function(err, data)
			if err then
				set_torrent_action_abort_message(self, 'changed')
				return
			end

			local selected_torrents = {}
			local tracker_list = {}
			local count = 0

			local function commit()
				if #tracker_list == 0 then
					return
				end

				local s = concat(tracker_list, '\n')

				local ids = {}

				for _, torrent in ipairs(selected_torrents) do
					if torrent.trackerList ~= s then
						insert(ids, assert(torrent.hashString))
					end
				end

				if #ids > 0 then
					count = count + #ids
					self.transmission:call('torrent-set', {
						ids = ids,
						trackerList = s,
					})
				end

				selected_torrents = {}
				tracker_list = {}
			end

			local new_tier = false

			for s in parse_fields(data, '.*') do
				local n = tonumber(match(s, '^%d+'))
				if n then
					commit()
					insert(selected_torrents, assert(torrents[n]))
				elseif s == '' then
					new_tier = true
				else
					if new_tier and #tracker_list > 0 then
						insert(tracker_list, '')
					end
					new_tier = false
					insert(tracker_list, s)
				end
			end

			commit()

			set_torrent_action_message(self, count, 'changed')
		end)
	end

