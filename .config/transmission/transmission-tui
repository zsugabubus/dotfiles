		elseif n < K then
			return format('%dB', n)
		elseif n < M then
			return format('%.1fK', ceil(n * 10 / K) / 10)
		elseif n < G then
			return format('%.1fM', ceil(n * 10 / M) / 10)
		elseif n < 100 * G then
