#!/usr/bin/luajit
local ffi = require('ffi')
local json = require('cjson')
local uv = require('luv')

local RFC_7273 = '%a, %d %b %Y %H:%M:%S %z'
local SECONDS_PER_MINUTE = 60
local SECONDS_PER_HOUR = 60 * SECONDS_PER_MINUTE
local SECONDS_PER_DAY = 24 * SECONDS_PER_HOUR

local function logger_factory(level)
	if level > (tonumber(os.getenv('RSS_LOG')) or 6) then
		return function() end
	end
	return function(s)
		io.stderr:write(('<%d>%s\n'):format(level, s))
	end
end

local log_error = logger_factory(3)
local log_warn = logger_factory(4)
local log_info = logger_factory(6)
local log_debug = logger_factory(7)

local function noop()
	-- Do nothing.
end

local function list_dir(path)
	local handle = uv.fs_scandir(path)
	if handle then
		return uv.fs_scandir_next, handle
	end
	return noop
end

local function get_hostname()
	local f = assert(io.open('/etc/hostname'))
	local hostname = assert(f:read('*l'))
	assert(f:close())
	return hostname
end

local function shesc(s)
	return "'" .. s:gsub("'", [['"'"']]) .. "'"
end

local function execute(args)
	local t = {}
	for _, arg in ipairs(args) do
		table.insert(t, shesc(arg))
	end
	local status = os.execute(table.concat(t, ' '))
	assert(status == 0)
end

local function format_duration(d)
	if d >= 2 * SECONDS_PER_DAY then
		return ('%d days'):format(d / SECONDS_PER_DAY)
	elseif d >= 26 * SECONDS_PER_HOUR then
		return ('1 day and %d hours'):format((d - SECONDS_PER_DAY) / SECONDS_PER_HOUR)
	elseif d >= 2 * SECONDS_PER_HOUR then
		return ('%d hours'):format(d / SECONDS_PER_HOUR)
	elseif d >= 2 * SECONDS_PER_MINUTE then
		return ('%d minutes'):format(d / SECONDS_PER_MINUTE)
	elseif d == 1 then
		return '1 second'
	end
	return ('%d seconds'):format(d)
end

local sha1, base64_encode = (function()
	local ssl = ffi.load('ssl')

	ffi.cdef([[
typedef struct EVP_MD EVP_MD;

enum { EVP_MAX_MD_SIZE = 64 };

const EVP_MD *EVP_sha1(void);
int EVP_Digest(const void *, size_t, unsigned char *, unsigned int *, const EVP_MD *, void *);
int OPENSSL_buf2hexstr_ex(char *, size_t, size_t *, const unsigned char *, long, const char);
int EVP_EncodeBlock(unsigned char *, const unsigned char *, int);
]])

	local md, md_size = ffi.new('unsigned char[?]', ssl.EVP_MAX_MD_SIZE), ffi.new('int[1]')
	local buf, buf_size =
		ffi.new('unsigned char[?]', ssl.EVP_MAX_MD_SIZE * 2 + 1), ffi.new('size_t[1]')

	local function generic(data, evp_type)
		assert(ssl.EVP_Digest(data, #data, md, md_size, evp_type, nil) == 1)
		assert(ssl.OPENSSL_buf2hexstr_ex(buf, ffi.sizeof(buf), buf_size, md, md_size[0], 0) == 1)
		return ffi.string(buf, buf_size[0] - 1 --[[ NUL ]])
	end

	local sha1_evp = ssl.EVP_sha1()

	local function sha1(data)
		return generic(data, sha1_evp)
	end

	local function base64_encode(s)
		local n = math.ceil(#s / 3) * 4
		local out = ffi.new('unsigned char[?]', n + 1 --[[ NUL ]])
		assert(ssl.EVP_EncodeBlock(out, s, #s) == n)
		return ffi.string(out, n)
	end

	return sha1, base64_encode
end)()

local compress, decompress = (function()
	local zlib = ffi.load('z')

	ffi.cdef([[
typedef struct gzFile_s *gzFile;

gzFile gzopen(const char *, const char *);
int gzread(gzFile, void *, unsigned);
int gzwrite(gzFile, const char *, unsigned);
int gzclose(gzFile);
]])

	local function compress(path, data)
		assert(#data == ffi.cast('unsigned', #data))
		local f = zlib.gzopen(path, 'w9')
		assert(f ~= nil)
		zlib.gzwrite(f, data, #data)
		assert(zlib.gzclose(f) == 0)
	end

	local function decompress(path)
		local f = zlib.gzopen(path, 'r')
		if f == nil then
			return
		end
		local buf = require('string.buffer'):new()
		repeat
			local ptr, len = buf:reserve(8192)
			local n = zlib.gzread(f, ptr, len)
			assert(n >= 0)
			buf:commit(n)
		until n < len
		assert(zlib.gzclose(f) == 0)
		return buf:tostring()
	end

	return compress, decompress
end)()

local HttpSession = (function()
	local curl = ffi.load('curl')

	ffi.cdef([[
struct curl_slist;

typedef struct CURL CURL;

struct curl_header {
	char *name;
	char *value;
};

enum {
	CURLH_HEADER = 1,
};

typedef enum {
	CURLE_OK = 0,
} CURLcode;

typedef enum {
	CURLOPT_SSL_VERIFYPEER = 0 + 64,
	CURLOPT_URL = 10000 + 2,
	CURLOPT_HTTPHEADER = 10000 + 23,
	CURLOPT_ACCEPT_ENCODING = 10000 + 102,
	CURLOPT_WRITEFUNCTION = 20000 + 11,
} CURLoption;

typedef enum {
	CURLINFO_RESPONSE_CODE = 0x200000 + 2,
} CURLINFO;

typedef enum {
	CURLHE_OK = 0,
	CURLHE_MISSING = 2,
} CURLHcode;

CURL *curl_easy_init(void);
CURLHcode curl_easy_header(CURL *, const char *, size_t, unsigned, int, struct curl_header **);
CURLcode curl_easy_getinfo(CURL *, CURLINFO, ...);
CURLcode curl_easy_perform(CURL *);
CURLcode curl_easy_setopt(CURL *, CURLoption, ...);
CURLcode curl_global_init(long);
const char *curl_easy_strerror(CURLcode);
struct curl_slist *curl_slist_append(struct curl_slist *, const char *);
void curl_easy_cleanup(CURL *);
void curl_easy_reset(CURL *);
void curl_slist_free_all(void *);

typedef size_t write_callback(char *, size_t, size_t, void *);
	]])

	assert(curl.curl_global_init(0xff) == curl.CURLE_OK)

	local function check(result)
		if result ~= curl.CURLE_OK then
			error(ffi.string(curl.curl_easy_strerror(result)), 0)
		end
	end

	local long_ref = ffi.new('long[1]')
	local header_ptr_ref = ffi.new('struct curl_header *[1]')

	local body = require('string.buffer').new()
	local function write_callback(buffer, size, nmemb)
		local len = size * nmemb
		body:putcdata(buffer, len)
		return len
	end
	write_callback = ffi.cast('write_callback *', write_callback)

	local M = {}
	M.__index = M

	local function make_header_list(headers)
		local list = nil
		for k, v in pairs(headers) do
			local data = ('%s%s%s'):format(k, v == '' and ';' or ':', v or '')
			local new_list = curl.curl_slist_append(list, data)
			assert(new_list ~= nil)
			if list ~= nil then
				ffi.gc(list, nil)
			end
			ffi.gc(new_list, curl.curl_slist_free_all)
			list = new_list
		end
		return list
	end

	local function long(x)
		return ffi.cast('long', x)
	end

	function M.new(cls)
		return setmetatable({
			handle = ffi.gc(curl.curl_easy_init(), curl.curl_easy_cleanup),
		}, cls)
	end

	function M:request(url, opts)
		body:reset()
		curl.curl_easy_reset(self.handle)
		check(curl.curl_easy_setopt(self.handle, curl.CURLOPT_URL, url))
		check(curl.curl_easy_setopt(self.handle, curl.CURLOPT_ACCEPT_ENCODING, ''))
		self._header_list = make_header_list(opts.headers)
		check(curl.curl_easy_setopt(self.handle, curl.CURLOPT_HTTPHEADER, self._header_list))
		if opts.insecure then
			check(curl.curl_easy_setopt(self.handle, curl.CURLOPT_SSL_VERIFYPEER, long(0)))
		end
		check(curl.curl_easy_setopt(self.handle, curl.CURLOPT_WRITEFUNCTION, write_callback))
		check(curl.curl_easy_perform(self.handle))
	end

	function M:body()
		return body:tostring()
	end

	function M:status()
		check(curl.curl_easy_getinfo(self.handle, curl.CURLINFO_RESPONSE_CODE, long_ref))
		return tonumber(long_ref[0])
	end

	function M:header(name)
		local result =
			curl.curl_easy_header(self.handle, name, 0, curl.CURLH_HEADER, -1, header_ptr_ref)
		if result == curl.CURLHE_MISSING then
			return nil
		end
		assert(result == curl.CURLHE_OK)
		local header = header_ptr_ref[0]
		return ffi.string(header.value)
	end

	return M
end)()

local Maildir = (function()
	local M = {}
	M.__index = M

	local hostname = get_hostname()
	local pid = uv.getpid()
	local counter = 0

	local function gen_name()
		counter = counter + 1
		return ('%s.%s_%d.%s'):format(os.time(), pid, counter, hostname)
	end

	local function make_message_lookup(path)
		local messages = {}
		for _, x in ipairs({ 'cur', 'new' }) do
			local dir = path .. '/' .. x
			for name in list_dir(dir) do
				local mail_path = dir .. '/' .. name
				local f = io.open(mail_path)
				if f then
					local data = assert(f:read(512))
					assert(f:close())
					local msg_id = assert(data:match('Message%-ID: *(<[^\r\n>]*>)'))
					messages[msg_id] = true
				end
			end
		end
		return messages
	end

	function M.new(cls, path)
		for _, x in ipairs({ 'tmp', 'cur', 'new' }) do
			uv.fs_mkdir(path .. '/' .. x, tonumber('700', 8))
		end
		return setmetatable({ _path = path }, cls)
	end

	function M:has_message(msg_id)
		if not self._messages then
			self._messages = make_message_lookup(self._path)
		end
		return self._messages[msg_id]
	end

	function M:add_message(msg_id, bytes)
		if self:has_message(msg_id) then
			return
		end

		local name = gen_name()
		local tmp_path = ('%s/tmp/%s'):format(self._path, name)
		local path = ('%s/new/%s'):format(self._path, name)

		local f = assert(io.open(tmp_path, 'w'))
		assert(f:write(bytes))
		assert(f:close())

		assert(os.rename(tmp_path, path))
		self._messages[msg_id] = true

		return path
	end

	return M
end)()

local parse_date = (function()
	local t = os.date('!*t', 0)
	local local_tz_offset = os.time(t)

	local function make_time(year, month, day, hour, min, sec, tz)
		t.year = year
		t.month = month
		t.day = day
		t.hour = hour
		t.min = min - tz
		t.sec = sec
		return os.time(t) - local_tz_offset
	end

	local TZ_GMT = 0

	local function parse_tz(tz_sign, tz_hour, tz_min)
		return (tz_sign == '-' and -1 or 1) * (tonumber(tz_hour) * 60 + tonumber(tz_min))
	end

	local MONTHS = {
		Jan = 1,
		Feb = 2,
		Mar = 3,
		Apr = 4,
		May = 5,
		Jun = 6,
		Jul = 7,
		Aug = 8,
		Sep = 9,
		Oct = 10,
		Nov = 11,
		Dec = 12,
	}

	return function(s)
		do
			local year, month, day, hour, min, sec, tz_sign, tz_hour, tz_min =
				s:match('^(%d%d%d%d)-(%d%d)-(%d%d)T(%d%d):(%d%d):(%d%d)([+-])(%d%d):?(%d%d)$')
			if day then
				return make_time(year, month, day, hour, min, sec, parse_tz(tz_sign, tz_hour, tz_min))
			end
		end

		do
			local year, month, day, hour, min, sec =
				s:match('^(%d%d%d%d)-(%d%d)-(%d%d)T(%d%d):(%d%d):(%d%d)Z$')
			if year then
				return make_time(year, month, day, hour, min, sec, TZ_GMT)
			end
		end

		do
			local year, month, day, hour, min, sec =
				s:match('^(%d%d%d%d)-(%d%d)-(%d%d)T(%d%d):(%d%d):(%d%d)%.%d%d%dZ$')
			if year then
				return make_time(year, month, day, hour, min, sec, TZ_GMT)
			end
		end

		do
			local year, month, day, hour, min = s:match('^(%d%d%d%d)-(%d%d)-(%d%d)T(%d%d):(%d%d)Z$')
			if year then
				return make_time(year, month, day, hour, min, 0, TZ_GMT)
			end
		end

		do
			local day, month_name, year, hour, min, sec, tz_sign, tz_hour, tz_min =
				s:match('^..., (%d%d) (%u%l%l) (%d%d%d%d) (%d%d):(%d%d):(%d%d) ([+-])(%d%d)(%d%d)$')
			if day then
				return make_time(
					year,
					assert(MONTHS[month_name]),
					day,
					hour,
					min,
					sec,
					parse_tz(tz_sign, tz_hour, tz_min)
				)
			end
		end

		do
			local day, month_name, year, hour, min, sec =
				s:match('^..., (%d%d) (%u%l%l) (%d%d%d%d) (%d%d):(%d%d):(%d%d) GMT$')
			if day then
				return make_time(year, assert(MONTHS[month_name]), day, hour, min, sec, TZ_GMT)
			end
		end

		do
			local year, month, day = s:match('^(%d%d%d%d)-(%d%d)-(%d%d)$')
			if year then
				return make_time(year, month, day, 0, 0, 0, TZ_GMT)
			end
		end

		do
			local year = s:match('^(%d%d%d%d)$')
			if year then
				return make_time(year, 1, 1, 0, 0, 0, TZ_GMT)
			end
		end

		do
			local year, month, day, hour, min, sec, tz_sign, tz_hour, tz_min =
				s:match('^(%d%d%d%d)-(%d%d)-(%d%d) (%d%d):(%d%d):(%d%d) ([+-])(%d%d)(%d%d)$')
			if day then
				return make_time(year, month, day, hour, min, sec, parse_tz(tz_sign, tz_hour, tz_min))
			end
		end

		error(('invalid date: %s'):format(s))
	end
end)()

local function url_hostname(url)
	return url:match('://([^/]*)'):gsub('.*@', ''):gsub(':.*', '')
end

local function url_join(a, b)
	if b:find('^/') then
		return a:match('.*://[^/]*') .. b
	end
	return b
end

local XmlNode = (function()
	local M = {}
	M.__index = M

	function M:find(tag)
		for _, child in ipairs(self) do
			if child.tag == tag then
				return child
			end
		end
	end

	function M:texts()
		local t = {}
		for _, child in ipairs(self) do
			if child.text ~= '' then
				t[child.tag] = child.text
			end
		end
		return t
	end

	function M:find_all(tag)
		return function(self, i)
			for i, child in next, self, i do
				if child.tag == tag then
					return i, child
				end
			end
		end,
			self
	end

	return M
end)()

local parse_xml = (function()
	local stack

	local CALLBACKS = {
		StartElement = function(_, tag, attribs)
			local parent_node = assert(stack[#stack])
			local node = setmetatable({
				tag = tag,
				attribs = attribs,
				text = '',
			}, XmlNode)
			table.insert(parent_node, node)
			table.insert(stack, node)
		end,
		EndElement = function()
			local closed_node = table.remove(stack)
			if closed_node.text then
				-- Trim whitespace.
				closed_node.text = closed_node.text:match('(%S.-)%s*$')
			end
		end,
		CharacterData = function(_, s)
			if s:find('%S') then
				local top_node = assert(stack[#stack])
				top_node.text = top_node.text .. s
			end
		end,
	}

	return function(s)
		local root = {}
		stack = { root }

		local parser = require('lxp').new(CALLBACKS)
		parser:parse(s)
		parser:parse()
		parser:close()

		assert(#root == 1)
		return root[1]
	end
end)()

local parse_feed = (function()
	local TEXT_HTML = 'text/html; charset="utf-8"'
	local TEXT_PLAIN = 'text/plain; charset="utf-8"'

	local function mime_payload(mime_type, payload)
		return { mime_type = assert(mime_type), payload = assert(payload) }
	end

	local function guess_html_or_plain_payload(s)
		return mime_payload(s:find('^<') and TEXT_HTML or TEXT_PLAIN, s)
	end

	local function parse_rss_categories(node)
		local categories = {}
		for _, category in node:find_all('category') do
			table.insert(categories, assert(category.text))
		end
		return categories
	end

	local function parse_rss(root)
		local entries = {}

		local version = root.attribs.version
		assert(version == '2.0' or version == '0.91')

		for _, channel in root:find_all('channel') do
			local x = channel:texts()
			local parent = {
				id = assert(x.link),
				title = assert(x.title),
				content = x.description and guess_html_or_plain_payload(x.description),
				link = assert(x.link),
				categories = parse_rss_categories(root),
			}

			for _, item in channel:find_all('item') do
				local x = item:texts()
				table.insert(entries, {
					parent = parent,
					id = assert(x.guid or x.link),
					title = assert(x.title),
					date = parse_date(assert(x.pubDate)),
					link = assert(x.link or x.guid),
					content = guess_html_or_plain_payload(x['content:encoded'] or x.description or ''),
					categories = parse_rss_categories(item),
				})
			end
		end

		return entries
	end

	local function parse_atom_categories(node)
		local categories = {}
		for _, category in node:find_all('category') do
			table.insert(categories, assert(category.attribs.label or category.attribs.term))
		end
		return categories
	end

	local function parse_atom_text(node)
		local is_text = (node.attribs.type or 'text') == 'text'
		return mime_payload(is_text and TEXT_PLAIN or TEXT_HTML, node.text)
	end

	local function parse_atom_entry_content(node)
		local content = node:find('content')
		if content then
			return parse_atom_text(content)
		end

		-- FIXME: Proper handling of namespaces.
		local media_group = node:find('media:group')
		if media_group then
			local media_description = media_group:find('media:description')
			if media_description and media_description.text then
				return mime_payload(TEXT_PLAIN, media_description.text)
			end
		end

		local summary = node.summary
		if summary then
			return parse_atom_text(summary)
		end
	end

	local function parse_atom_alternate_link(node)
		for _, link in node:find_all('link') do
			if (link.attribs.rel or 'alternate') == 'alternate' then
				return link.attribs.href
			end
		end
	end

	local function parse_atom(root)
		local entries = {}

		local x = root:texts()
		local parent = {
			id = assert(x.id),
			title = assert(x.title or ''),
			content = x.subtitle and mime_payload(TEXT_PLAIN, x.subtitle),
			link = assert(parse_atom_alternate_link(root)),
			categories = parse_atom_categories(root),
		}

		for _, entry in root:find_all('entry') do
			local x = entry:texts()
			local link = url_join(parent.link, assert(assert(entry:find('link')).attribs.href))
			table.insert(entries, {
				parent = parent,
				id = assert(x.id or link),
				title = assert(x.title),
				link = link,
				date = parse_date(assert(x.published or x.updated)),
				content = parse_atom_entry_content(entry),
				categories = parse_atom_categories(entry),
			})
		end

		return entries
	end

	local function parse_root(root)
		if root.tag == 'rss' then
			return parse_rss(root)
		elseif root.tag == 'feed' then
			return parse_atom(root)
		else
			error(('invalid root tag: %s'):format(root.tag))
		end
	end

	return function(s)
		return parse_root(parse_xml(s))
	end
end)()

local function mime_encode(s)
	if s:find('[^ -~]') then
		return ('=?utf-8?b?%s?='):format(base64_encode(s))
	end
	return s
end

local function deep_equal(a, b)
	if a == b then
		return true
	elseif type(a) == 'table' and type(b) == 'table' and #a == #b then
		for k in pairs(b) do
			if a[k] == nil then
				return false
			end
		end
		for k, a_k in pairs(a) do
			if not deep_equal(b[k], a_k) then
				return false
			end
		end
		return true
	end
	return false
end

local function shallow_copy(a)
	local copy = {}
	for k, v in pairs(a) do
		copy[k] = v
	end
	return copy
end

local function read_state(path)
	return json.decode(decompress(path) or '{}')
end

local function write_state(path, state)
	local tmp_path = path .. '.' .. uv.getpid() .. '~'
	compress(tmp_path, json.encode(state))
	assert(os.rename(tmp_path, path))
end

local Feed = (function()
	local M = {
		_filter = function()
			return true
		end,
	}
	M.__index = M

	function M.new(cls)
		return setmetatable({}, cls)
	end

	function M:id(id)
		self._id = id
		return self
	end

	function M:from(fn)
		self._from = fn
		return self
	end

	function M:to(fn)
		self._to = fn
		return self
	end

	function M:filter(fn)
		self._filter = fn
		return self
	end

	function M:at_hour(hour)
		function self._expiry(updated)
			if not updated then
				return 0
			end
			local t = os.date('*t', updated)
			if hour <= t.hour then
				t.day = t.day + 1
			end
			t.hour = hour
			t.min = 0
			t.sec = 0
			t.isdst = nil
			return os.time(t)
		end
		return self
	end

	function M:on_weekday(day_name)
		function self._expiry(updated)
			if not updated then
				return 0
			end
			local t = os.date('*t', updated)
			t.hour = 0
			t.min = 0
			t.sec = 0
			t.isdst = nil
			for _ = 1, 7 do
				t.day = t.day + 1
				local x = os.time(t)
				if os.date('%a', x) == day_name then
					return x
				end
			end
			error(('invalid day: %q'):format(day_name))
		end
		return self
	end

	function M:ttl_seconds(seconds)
		function self._expiry(updated)
			if not updated then
				return 0
			end
			return updated + seconds
		end
		return self
	end

	function M:ttl_minutes(minutes)
		return self:ttl_seconds(minutes * SECONDS_PER_MINUTE)
	end

	function M:ttl_hours(hours)
		return self:ttl_seconds(hours * SECONDS_PER_HOUR)
	end

	function M:ttl_days(days)
		return self:ttl_seconds(days * SECONDS_PER_DAY)
	end

	function M:disable()
		function self._expiry() end
		return self
	end

	return M
end)()

local function update_feeds(feeds, state_path)
	local function process_entries(entries, cursor, callback)
		local new_cursor = cursor
		for _, entry in ipairs(entries) do
			if entry.date > cursor then
				new_cursor = math.max(new_cursor, entry.date)
				callback(entry)
			end
		end
		return new_cursor
	end

	local function process_feed(feed, state)
		local now = os.time()
		local expiry = feed._expiry(state.updated)

		if not expiry then
			log_debug(('Feed %s is disabled'):format(feed._id))
			return
		elseif expiry == 0 then
			log_info(('Feed %s is new'):format(feed._id))
		elseif expiry > now then
			log_debug(
				('Feed %s expires in %s at %s'):format(
					feed._id,
					format_duration(os.difftime(expiry, now)),
					os.date(RFC_7273, expiry)
				)
			)
			return
		else
			log_debug(
				('Feed %s expired %s ago at %s'):format(
					feed._id,
					format_duration(os.difftime(now, expiry)),
					os.date(RFC_7273, expiry)
				)
			)
		end

		log_debug(('Fetch feed %s'):format(feed._id))
		local entries = feed._from(state)
		if not entries then
			return
		end

		state.updated = os.time()
		state.cursor = process_entries(entries, state.cursor or 0, function(entry)
			if not feed._filter(entry) then
				log_debug(('Feed %s filtered: %s'):format(feed._id, entry.title))
				return
			end
			feed._to(entry)
		end)
	end

	local old_state = read_state(state_path)
	local new_state = {}

	for _, feed in ipairs(feeds) do
		assert(not new_state[feed._id], ('duplicated feed: %s'):format(feed._id))
		local feed_state = shallow_copy(old_state[feed._id] or {})
		process_feed(feed, feed_state)
		new_state[feed._id] = feed_state
	end

	if deep_equal(new_state, old_state) then
		log_debug('State unchanged')
	else
		write_state(state_path, new_state)
	end
end

local expand_path = (function()
	local mail = os.getenv('MAIL')
	local home = os.getenv('HOME')

	return function(path)
		if path:sub(1, 2) == '=/' or path == '=' then
			return assert(mail, '$MAIL unset') .. path:sub(2)
		elseif path:sub(1, 2) == '~/' or path == '~' then
			return assert(home, '$HOME unset') .. path:sub(2)
		end
		return path
	end
end)()

local gen_mail = (function()
	local function gen_msg_id(data, host)
		return ('<%s@%s>'):format(sha1(data):sub(1, 10):lower(), host)
	end

	local function sanitize(s)
		return s:gsub('[\n\r]', '')
	end

	local buf = require('string.buffer'):new()

	return function(entry, name_override)
		local host = assert(url_hostname(entry.link))
		local msg_id = gen_msg_id(entry.id, host)
		buf:reset()
		buf:putf('Received: mrss; %s\n', os.date(RFC_7273))
		if entry.parent then
			buf:putf('In-Reply-To: %s\n', gen_msg_id(entry.parent.id, host))
		end
		buf:putf('Message-ID: %s\n', msg_id)
		buf:putf('Date: %s\n', os.date(RFC_7273, entry.date))
		buf:putf(
			'From: "%s" <feed@%s>\n',
			sanitize(name_override or (entry.parent or entry).title),
			host
		)
		buf:putf('Subject: %s\n', mime_encode(sanitize(entry.title)))
		buf:putf('Link: %s\n', sanitize(entry.link))
		if entry.parent then
			for _, category in ipairs(entry.parent.categories) do
				buf:putf('X-Category: %s\n', sanitize(category))
			end
		end
		for _, category in ipairs(entry.categories) do
			buf:putf('X-Category: %s\n', sanitize(category))
		end
		if entry.content then
			buf:putf('Content-Type: %s\n', entry.content.mime_type)
			buf:put('Content-Transfer-Encoding: 8bit\n')
			buf:put('\n')
			buf:put(entry.content.payload)
		end
		return msg_id, buf:tostring()
	end
end)()

local function main(args)
	os.setlocale('C')

	local http = HttpSession:new()
	local host_blacklist = {}
	local maildirs = setmetatable({}, {
		__mode = 'v',
		__index = function(t, path)
			log_debug(('Opening maildir at %s'):format(path))
			local maildir = Maildir:new(path)
			t[path] = maildir
			return maildir
		end,
	})

	_G.rss = {
		feed = function()
			return Feed:new()
		end,
		http = function(url, opts)
			local user_agent = opts and opts.user_agent
			local insecure = opts and opts.insecure
			return function(state)
				local host = assert(url_hostname(url))

				if host_blacklist[host] then
					log_debug('Skip blacklisted')
					return
				end

				local ok, err = pcall(function()
					http:request(url, {
						headers = {
							['User-Agent'] = user_agent,
							['If-Modified-Since'] = state.last_modified,
							['If-None-Match'] = state.etag,
						},
						insecure = insecure,
					})
				end)
				if not ok then
					log_error(('Request GET %s failed: %s'):format(url, err))
					return
				end

				local status = http:status()
				log_debug(('GET %s %d'):format(url, status))

				if status == 304 then
					log_debug('Not modified')
					return {}
				end

				if status == 429 then
					log_debug(('Blacklist host: %s'):format(host))
					host_blacklist[host] = true
					return
				end

				if status ~= 200 then
					log_error(('Got HTTP %d: %s'):format(status, url))
					local location = http:header('Location')
					if location then
						log_warn(('New location: %s'):format(location))
					end
					return
				end

				state.last_modified = http:header('Last-Modified')
				state.etag = http:header('ETag')

				return parse_feed(http:body())
			end
		end,
		maildir = function(path, opts)
			local maildir = maildirs[expand_path(path)]
			local name = opts and opts.name
			local reply_to = opts and opts.reply_to
			local function deliver(entry)
				local mail_path = maildir:add_message(gen_mail(entry, name))
				if mail_path then
					log_debug(
						('New message %s: [%s] %s'):format(
							mail_path,
							os.date('%Y-%m-%d', entry.date),
							entry.title
						)
					)
				else
					log_debug(('Message already exists: %s'):format(entry.title))
				end
			end
			return function(entry)
				deliver(entry)
				if reply_to then
					deliver(assert(entry.parent))
				end
			end
		end,
		cmd = function(cmdline)
			local function write_json(path, data)
				local f = io.open(path, 'w')
				assert(f:write(json.encode(data)))
				assert(f:close())
			end
			local function read_json(path)
				local f = io.open(path)
				local data = json.decode(assert(f:read('*a')))
				assert(f:close())
				if data == json.null then
					return nil
				end
				return data
			end
			return function(state)
				log_debug(('Execute %s'):format(cmdline))
				local state_path = os.tmpname()
				write_json(state_path, state.external)
				local f = assert(
					io.popen(('set -eu; export RSS_STATE_FILE=%s; %s'):format(shesc(state_path), cmdline))
				)
				local s = assert(f:read('*a'))
				assert(f:close())
				local new_external = read_json(state_path)
				assert(os.remove(state_path))
				if s == '' then
					log_error(('Got empty output: %s'):format(cmdline))
					return
				end
				state.external = new_external
				return parse_feed(s)
			end
		end,
		transmission = function()
			return function(entry)
				local url = entry.link
				log_debug(('Add torrent to Transmission: %s'):format(url))
				execute({ 'transmission-remote', '--add', url })
			end
		end,
		include = function(patterns)
			assert(#patterns > 0, 'no patterns')
			return function(entry)
				for _, pattern in ipairs(patterns) do
					if entry.title:find(pattern) then
						return true
					end
				end
			end
		end,
		exclude = function(...)
			local include = _G.rss.include(...)
			return function(...)
				return not include(...)
			end
		end,
	}

	local config_path = assert(args[1], 'Missing config file')
	local config = assert(dofile(config_path))
	update_feeds(config, expand_path(assert(config.state)))
end

local function test()
	local function eq(left, right)
		return assert(left == right, ('Expected %q == %q'):format(left, right))
	end

	local function parse_date_and_format(s)
		return os.date('!%Y-%m-%d %H:%M:%S', parse_date(s))
	end
	eq(0, parse_date('1970-01-01T00:00:00Z'))
	eq('2000-01-01 00:00:00', parse_date_and_format('2000'))
	eq('2000-01-02 00:00:00', parse_date_and_format('2000-01-02'))
	eq('2000-01-02 03:04:00', parse_date_and_format('2000-01-02T03:04Z'))
	eq('2000-01-02 03:04:05', parse_date_and_format('2000-01-02T03:04:05Z'))
	eq('2050-12-24 18:36:59', parse_date_and_format('2050-12-24T18:36:59Z'))
	eq('2000-01-01 23:00:05', parse_date_and_format('Xxx, 02 Jan 2000 03:04:05 +0404'))
	eq('2000-01-02 06:34:05', parse_date_and_format('2000-01-02T03:04:05-03:30'))
	eq('2000-01-02 06:34:05', parse_date_and_format('2000-01-02T03:04:05-0330'))
	eq('2000-01-02 03:04:05', parse_date_and_format('2000-01-02T03:04:05.678Z'))
	eq('2000-01-02 08:34:05', parse_date_and_format('2000-01-02 03:04:05 -0530'))
	eq('2000-01-02 01:00:05', parse_date_and_format('2000-01-02 03:04:05 +0204'))

	eq('0 seconds', format_duration(0))
	eq('1 second', format_duration(1))
	eq('60 seconds', format_duration(60))
	eq('119 seconds', format_duration(119))
	eq('2 minutes', format_duration(120))
	eq('60 minutes', format_duration(3600))
	eq('90 minutes', format_duration(1.5 * 3600))
	eq('119 minutes', format_duration(2 * 3600 - 1))
	eq('2 hours', format_duration(2 * 3600))
	eq('24 hours', format_duration(24 * 3600))
	eq('25 hours', format_duration(25 * 3600))
	eq('25 hours', format_duration(26 * 3600 - 1))
	eq('1 day and 2 hours', format_duration(26 * 3600))
	eq('1 day and 23 hours', format_duration(48 * 3600 - 1))
	eq('2 days', format_duration(48 * 3600))
	eq('100 days', format_duration(100 * 24 * 3600))

	local url = 'http://user:password@www.host:80/p/a/t/h/index.html?query=1#fragment'
	eq('www.host', url_hostname(url))
	eq(
		'http://user:password@www.host:80/new/path.html?search=foo#bar',
		url_join(url, '/new/path.html?search=foo#bar')
	)
end
