#!/usr/bin/luajit
local uv = require('luv')

local KiB = 1024
local MiB = 1024 * KiB
local GiB = 1024 * MiB

local function bytes(n)
	if n < KiB then
		return ('%dB'):format(n)
	elseif n < MiB then
		return ('%dK'):format(n / KiB)
	elseif n < GiB then
		return ('%dM'):format(n / MiB)
	else
		return ('%dG'):format(n / GiB)
	end
end

local function bytes_long(n)
	if n < KiB then
		return ('%dB'):format(n)
	elseif n < MiB then
		return ('%dK'):format(n / KiB)
	elseif n < GiB then
		return ('%.1fM'):format(n / MiB)
	else
		return ('%.1fG'):format(n / GiB)
	end
end

local function noop()
	-- Do nothing.
end

local function list_dir(path)
	local handle = uv.fs_scandir(path)
	if handle then
		return uv.fs_scandir_next, handle
	end
	return noop
end

local function debounce(fn, delay, interval)
	local timer = uv.new_timer()
	local should_call

	local function handler()
		if should_call then
			should_call = false
			fn()
		else
			timer:stop()
		end
	end

	return function()
		should_call = true
		if not timer:is_active() then
			timer:start(delay, interval, handler)
		end
	end
end

local function file(path)
	local f = assert(io.open(path))
	f:setvbuf('no')

	return function(thismuch)
		f:seek('set')
		return assert(f:read(thismuch))
	end
end

local function popen(cmd, thismuch)
	local f = io.popen(cmd)
	local s = assert(f:read(thismuch))
	assert(f:close())
	return s
end

local function periodic(fn)
	return function(update_bar, ...)
		local o = {}
		local timer = uv.new_timer()
		local next_secs
		local update_block = fn(...)

		local function update()
			if next_secs then
				timer:start(next_secs * 1000, 0, update)
				next_secs = nil
				update_block(o)
				update_bar()
			end
		end

		function o:interval(secs)
			next_secs = secs
			if not timer:is_active() then
				update()
			end
		end

		return o
	end
end

local blocks = {
	net = periodic(function(pred)
		local pat = '\n *([^:\n]*): *(%d*) *' .. ('%d* *'):rep(7) .. '(%d*)'

		local f = file('/proc/net/dev')

		local prev_time = math.huge
		local prev_rx_bytes = 0
		local prev_tx_bytes = 0

		return function(o)
			local time = uv.now()
			local rx_bytes = 0
			local tx_bytes = 0

			for name, rx, tx in f(8192):gmatch(pat) do
				if pred(name) then
					rx_bytes = rx_bytes + tonumber(rx)
					tx_bytes = tx_bytes + tonumber(tx)
				end
			end

			local delta_time = time - prev_time

			o.rx_bytes = rx_bytes
			o.tx_bytes = tx_bytes

			if delta_time <= 0 then
				o.rx_speed = 0
				o.tx_speed = 0
			else
				o.rx_speed = (rx_bytes - prev_rx_bytes) * 1000 / delta_time
				o.tx_speed = (tx_bytes - prev_tx_bytes) * 1000 / delta_time
			end

			prev_rx_bytes = rx_bytes
			prev_tx_bytes = tx_bytes
			prev_time = time
		end
	end),
	mem = periodic(function()
		local f = file('/proc/meminfo')
		local t = {}

		return function(o)
			for name, n in f(84):gmatch('([^:]*): *(%d*) kB\n') do
				t[name] = tonumber(n) * 1024
			end

			o.total_bytes = t.MemTotal
			o.avail_bytes = t.MemAvailable
			o.used_bytes = o.total_bytes - o.avail_bytes
			o.used_percent = o.used_bytes * 100 / o.total_bytes
		end
	end),
	cpu = periodic(function()
		local f = file('/proc/stat')

		local prev_total = 0
		local prev_idle = 0

		return function(o)
			local i = 0
			local total = 0
			local idle = 0

			for n in f('*l'):gmatch('%d+') do
				n = tonumber(n)
				total = total + n
				i = i + 1
				if i == 4 then
					idle = n
				end
			end

			local delta_total = total - prev_total
			local delta_idle = idle - prev_idle

			if delta_total == 0 then
				o.usage = 0
			else
				o.usage = (1 - delta_idle / delta_total) * 100
			end

			prev_total = total
			prev_idle = idle
		end
	end),
	loadavg = periodic(function()
		local f = file('/proc/loadavg')

		return function(o)
			local avg_1, avg_5, avg_15 =
				f(50):match('^(%d*%.%d*) (%d*%.%d*) (%d*%.%d*)')
			o.avg_1 = tonumber(avg_1)
			o.avg_5 = tonumber(avg_5)
			o.avg_15 = tonumber(avg_15)
		end
	end),
	ac_online = periodic(function(name)
		local f = file(('/sys/class/power_supply/%s/online'):format(name or 'AC'))

		return function(o)
			o.online = f(1) == '1'
		end
	end),
	bat_capacity = periodic(function(name)
		local f =
			file(('/sys/class/power_supply/%s/capacity'):format(name or 'BAT0'))

		return function(o)
			o.capacity = tonumber(f(20))
		end
	end),
	transmission = periodic(function(url, user)
		local function get_session_stats(session_id)
			local cmd = ([[curl '%s' --max-time 1 --silent --user '%s' --header 'X-Transmission-Session-Id: %s' --json '{"method":"session-stats"}']]):format(
				url or 'http://localhost:9091/transmission/rpc',
				user or ':',
				session_id or ''
			)
			return popen(cmd, '*a')
		end

		local function get_session_id()
			return get_session_stats():match('.*: (%w+)')
		end

		local function json_number(s, pat)
			return tonumber(s:match(pat .. ':(%d+)'))
		end

		return function(o)
			local session_id = get_session_id()
			local stats = session_id and get_session_stats(session_id)
			o.active_torrent_count = stats
				and json_number(stats, '"activeTorrentCount"')
			o.paused_torrent_count = stats
				and json_number(stats, '"pausedTorrentCount"')
		end
	end),
	mail = function(update_bar, opts)
		local folders = {}
		local folders_by_display = {}
		local ring_timer = uv.new_timer()
		local ring_process

		local function ring()
			if ring_process then
				return
			end

			ring_process = uv.spawn('ffplay', {
				args = {
					'-autoexit',
					'-nodisp',
					'-loglevel',
					'error',
					'--',
					opts.bell_file,
				},
			}, function(code)
				ring_process:close()
				ring_process = nil
				assert(code == 0)
			end)
		end

		local function update_ring()
			local should_ring = false

			for _, folder in ipairs(folders) do
				if not folder.silent and folder.unread then
					should_ring = true
					break
				end
			end

			if should_ring then
				if not ring_timer:is_active() then
					ring_timer:start(0, 120 * 1000, ring)
				end
			else
				ring_timer:stop()
			end
		end

		local function count_files(path)
			local n = 0
			for _ in list_dir(path) do
				n = n + 1
			end
			return n
		end

		local function load_config(path)
			local ok, code = pcall(loadfile, path .. '/watch.lua')
			if ok and code then
				setfenv(code, {})
				return code()
			end
		end

		local function update_folders()
			for _, folder in ipairs(folders) do
				if not folder.root then
					local display_root = folder.display:match('^[^/]*')
					folder.root = folders_by_display[display_root]
				end
			end
		end

		local function add_folder(path, fullname, config)
			local name = fullname:match('([^/]*)$')
			local display = fullname:sub(2):gsub('/inbox$', '')
			local new_path = path .. '/new'

			local folder = {
				fullname = fullname,
				display = display,
				path = path,
				name = name,
				inbox = name == 'inbox',
				new_mails = count_files(new_path),
				unread = false,
				silent = false,
			}
			table.insert(folders, folder)
			folders_by_display[display] = folder

			for k, v in pairs(config or {}) do
				folder[k] = v
			end

			update_folders()

			local function update_count()
				local prev = folder.new_mails
				local curr = count_files(new_path)
				folder.new_mails = curr

				if curr > prev then
					folder.unread = true
				elseif curr < prev then
					folder.unread = false
				end

				update_bar()
				update_ring()
			end
			update_count = debounce(update_count, 50, 3000)

			local fs_event = uv.new_fs_event()
			fs_event:start(new_path, {}, function(err)
				assert(not err, err)
				update_count()
			end)
		end

		local function find_folders(path, fullname, config)
			config = load_config(path) or config

			if uv.fs_access(path .. '/new', 'x') then
				add_folder(path, fullname, config)
			end

			for name, kind in list_dir(path) do
				if
					kind == 'file'
					or name:sub(1, 1) == '.'
					or name == 'cur'
					or name == 'new'
					or name == 'tmp'
				then
					-- Ignore.
				else
					find_folders(path .. '/' .. name, fullname .. '/' .. name, config)
				end
			end
		end

		find_folders(assert(opts.mail_dir or os.getenv('MAIL')), '')

		table.sort(folders, function(a, b)
			if a.root.inbox ~= b.root.inbox then
				return a.root.inbox
			end
			return a.display < b.display
		end)

		return { folders = folders }
	end,
	system_units = periodic(function()
		return function(o)
			local status = popen('systemctl is-system-running', '*l')
			o.ok = status == 'starting' or status == 'running'
		end
	end),
	user_units = periodic(function()
		return function(o)
			local status = popen('systemctl --user is-system-running', '*l')
			o.ok = status == 'starting' or status == 'running'
		end
	end),
	logs = function(update_bar, opts)
		local o = { found = false }

		local args = {
			'--since=now',
			'--follow',
			'--output=cat',
			'--output-fields=MESSAGE',
			'--priority=' .. (opts.priority or 'err'),
		}
		local function unit_filters(units)
			return units == true and { '*' } or units or {}
		end
		for _, s in ipairs(unit_filters(opts.system_units)) do
			table.insert(args, '--unit=' .. s)
		end
		for _, s in ipairs(unit_filters(opts.user_units)) do
			table.insert(args, '--user-unit=' .. s)
		end

		local stdout = uv.new_pipe()
		assert(uv.spawn('journalctl', {
			args = args,
			stdio = { nil, stdout, 2 },
		}))
		stdout:read_start(function(err, data)
			assert(not err, err)
			assert(data)
			o.found = true
			update_bar()
		end)

		return o
	end,
	alsa = function(update_bar, control)
		local o = { volume = 0, muted = false }

		local function update()
			local stdout = uv.new_pipe()
			local process
			process = assert(uv.spawn('amixer', {
				args = { '-M', 'get', control },
				stdio = { nil, stdout, 2 },
			}, function()
				process:close()
			end))
			stdout:read_start(function(err, data)
				assert(not err, err)
				stdout:close()
				local volume, toggle =
					data:match('Playback[^\n]*%[(%d+)%%%][^\n]*%[o([nf])')
				o.volume = tonumber(volume)
				o.muted = toggle == 'f'
				update_bar()
			end)
		end
		local debounced_update = debounce(update, 50, 1000)

		local needle = control .. ' Playback '
		local stdout = uv.new_pipe()
		assert(uv.spawn('stdbuf', {
			args = { '-oL', 'amixer', 'events' },
			stdio = { nil, stdout, 2 },
		}))
		stdout:read_start(function(err, data)
			assert(not err, err)
			if data:find(needle, 1, true) then
				debounced_update()
			end
		end)

		update()
		return o
	end,
}

local function bar(fn, on_output)
	local buf = require('string.buffer').new()
	local last_output
	local write

	local function update()
		buf:reset()

		write(buf)

		local output = buf:tostring()
		if output == last_output then
			return
		end
		last_output = output

		on_output(output)
	end

	write = fn(debounce(update, 50, 500))

	update()
end

local function tmux(option, fn)
	bar(fn, function(output)
		local process
		process = assert(uv.spawn('tmux', {
			args = { 'set', '-g', option, output },
		}, function(code)
			process:close()
			assert(code == 0)
		end))
	end)
end

tmux('@status', function(update_bar)
	local function danger(cond)
		if not cond then
			return ''
		end
		return '#[bg=red,fg=color255,bold]!!#[default]'
	end

	local net = blocks.net(update_bar, function(name)
		return name:match('^enp') or name:match('^wl')
	end)
	local mem = blocks.mem(update_bar)
	local cpu = blocks.cpu(update_bar)
	local loadavg = blocks.loadavg(update_bar)
	local ac_online = blocks.ac_online(update_bar)
	local bat_capacity = blocks.bat_capacity(update_bar)
	local tr = blocks.transmission(update_bar)
	local mail = blocks.mail(update_bar, {
		bell_file = assert(os.getenv('HOME')) .. '/.config/tmux/new-mail.mp3',
	})
	local system_units = blocks.system_units(update_bar)
	local user_units = blocks.user_units(update_bar)
	local user_errors = blocks.logs(update_bar, { user_units = true })
	local alsa = blocks.alsa(update_bar, 'Master')

	do
		local signal = uv.new_signal()
		signal:unref()
		signal:start('sigusr1', function()
			user_errors.found = false
			update_bar()
		end)
	end

	return function(buf)
		do
			local empty = true

			for _, folder in ipairs(mail.folders) do
				if folder.new_mails > 0 then
					if empty then
						empty = false
						buf:put('[')
					else
						buf:put(' ')
					end

					buf:putf(
						'%s%s:%d%s',
						folder.unread
								and (folder.silent and '#[#{@status-mail-unread-silent-style}]' or '#[#{@status-mail-unread-style}]')
							or '',
						folder.display,
						folder.new_mails,
						folder.unread and '*#[default]' or ''
					)
				end
			end

			if not empty then
				buf:put('] ')
			end
		end

		net:interval(30)
		buf:put(' ↓ ', bytes(net.rx_bytes))
		if net.rx_speed > 50 * KiB then
			buf:put('/#[fg=color34,bold]', bytes_long(net.rx_speed), '#[default]')
		end
		buf:put(' ↑ ', bytes(net.tx_bytes))
		if net.tx_speed > 50 * KiB then
			buf:put('/#[fg=color33,bold]', bytes_long(net.tx_speed), '#[default]')
		end
		buf:put(' ')

		tr:interval(300)
		if (tr.paused_torrent_count or 0) > 0 then
			buf:put(' 󰍇 ', tr.paused_torrent_count, ' ')
		end

		mem:interval(15)
		buf:put(
			' ',
			bytes_long(mem.avail_bytes),
			danger(mem.avail_bytes < 1 * GiB),
			' '
		)

		loadavg:interval(30)
		if loadavg.avg_1 >= 1.5 and loadavg.avg_5 >= 1.5 then
			cpu:interval(30)
			buf:putf('  %d%% %.2f/%.2f ', cpu.usage, loadavg.avg_1, loadavg.avg_5)
		end

		ac_online:interval(60)
		if not ac_online.online then
			bat_capacity:interval(60)
			buf:putf(
				' ⚡%d%%%s ',
				bat_capacity.capacity,
				danger(bat_capacity.capacity < 50)
			)
		end

		if alsa.muted then
			buf:put(' [M] ')
		end

		user_units:interval(300)
		if not user_units.ok then
			buf:put(' #[fg=red,bold][u]#[default] ')
		elseif user_errors.found then
			buf:put(' #[fg=red,bold][e]#[default] ')
		end

		system_units:interval(300)
		if not system_units.ok then
			buf:put(' #[fg=red,bold][U]#[default] ')
		end
	end
end)

uv.run()
