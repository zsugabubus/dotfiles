#!/usr/bin/luajit
local ffi = require('ffi')
local uv = require('luv')
local json = require('cjson')
local curs = ffi.load('ncursesw')

os.setlocale('')

ffi.cdef([[
typedef struct WINDOW WINDOW;

enum {
	A_NORMAL = 0,
	A_REVERSE = 1 << 18,
	A_BOLD = 1 << 21,
};

extern int LINES, COLS;

WINDOW *initscr(void);
WINDOW *newwin(int, int, int, int);
char const *keyname(int);
int curs_set(int);
int doupdate(void);
int endwin(void);
int getcurx(const WINDOW *);
int getmaxx(const WINDOW *);
int getmaxy(const WINDOW *);
int keypad(WINDOW *win, bool);
int mvwin(WINDOW *, int, int);
int nodelay(WINDOW *, bool);
int noecho(void);
int waddnstr(WINDOW *, const char *, int);
int wattr_set(WINDOW *, uint32_t, short, void *);
int wclrtoeol(WINDOW *);
int wgetch(WINDOW *);
int wmove(WINDOW *, int, int);
int wnoutrefresh(WINDOW *);
int wresize(WINDOW *, int, int);
int wscrl(WINDOW *, int);
]])

ffi.metatype('WINDOW', {
	__index = {
		attr = function(self, attrs, pair)
			return curs.wattr_set(self, attrs, pair, nil)
		end,
		clrtoeol = curs.wclrtoeol,
		cols = curs.getmaxx,
		cursor = curs.wmove,
		getch = curs.wgetch,
		keypad = curs.keypad,
		lines = curs.getmaxy,
		move = curs.mvwin,
		nodelay = curs.nodelay,
		put = function(self, s)
			return curs.waddnstr(self, s, #s)
		end,
		putf = function(self, ...)
			return self:put(string.format(...))
		end,
		refresh = curs.wnoutrefresh,
		resize = curs.wresize,
		scroll = curs.wscrl,
		x = curs.getcurx,
	},
})

local Client = {}
Client.__index = Client

function Client.new(cls, ipc_server)
	local self = setmetatable({
		ipc_server = ipc_server,
		pipe = uv.new_pipe(),
		event_handlers = {},
	}, cls)

	self.uv_cb = function(err)
		if err then
			return self:close()
		end
	end

	return self
end

function Client:close()
	self.pipe:close()
end

function Client:request(command, on_reply)
	self.request_id = self.request_id + 1

	local request = {
		request_id = self.request_id,
		command = command,
		async = true,
	}

	self.reply_handlers[self.request_id] = on_reply

	self.pipe:write({ json.encode(request), '\n' }, self.uv_cb)
end

function Client:on(name, on_event)
	self.event_handlers[name] = on_event
end

function Client:connect(callback)
	self.request_id = 0
	self.reply_handlers = {}
	self.pipe:connect(self.ipc_server, function(err)
		if err then
			return callback(err)
		end

		local buffer = ''
		self.pipe:read_start(function(_, data)
			if not data then
				self:close()
				return
			end

			for line, eol in (buffer .. data):gmatch('([^\n]*)(\n?)') do
				if eol == '' then
					buffer = line
					break
				end

				local msg = json.decode(line)
				if msg.event then
					local handler = self.event_handlers[msg.event]
					if handler then
						handler(msg)
					end
				else
					local handler = self.reply_handlers[msg.request_id]
					if handler then
						handler(msg)
					end
				end
			end
		end)

		return callback()
	end)
end

do
	local signal = uv.new_signal()
	signal:unref()
	signal:start('sigint', function()
		uv.stop()
	end)
end

do
	local signal = uv.new_signal()
	signal:unref()
	signal:start('sigpipe', function() end)
end

local client
local tmpname
local props = {
	volume = 0,
	speed = 1,
	playlist = {},
	['playlist-count'] = 0,
	['playlist-pos-1'] = 0,
	['term-osd-bar-chars'] = '[-+-]',
}

local scrolloff = 5
local top = 0
local shellout
local stdin = uv.new_poll(0)
stdin:unref()
local sigwinch = uv.new_signal()
sigwinch:unref()
local playlist_timer = uv.new_timer()
playlist_timer:unref()

curs.initscr()
curs.noecho()
curs.curs_set(0)
local playlist_win = curs.newwin(1, 0, 0, 0)
local status_win = curs.newwin(1, 0, 0, 0)
status_win:nodelay(true)
status_win:keypad(true)

local function render_playlist()
	local win = playlist_win
	local lines = win:lines()
	local pos = props['playlist-pos-1']
	local playlist = props.playlist

	local old_top = top
	top = math.min(top, pos - scrolloff)
	top = math.max(top, pos + scrolloff - lines + 1)
	top = math.min(top, #playlist - lines + 1)
	top = math.max(1, top)

	win:scroll(top - old_top)

	local bottom = math.min(top + lines - 1, #playlist)
	for i = 0, bottom - top do
		local entry = playlist[top + i]
		win:attr(curs.A_NORMAL, 0)
		win:cursor(i, 0)
		win:put(' ')
		if top + i == pos then
			win:attr(curs.A_BOLD + curs.A_REVERSE, 0)
		end
		win:put(entry.filename)
		win:clrtoeol()
	end

	win:attr(curs.A_NORMAL, 0)
	for i = bottom - top + 1, lines - 1 do
		win:cursor(i, 0)
		win:put('~')
		win:clrtoeol()
	end

	win:refresh()
end

local function format_time(sec)
	local sign = sec < 0 and '-' or ''
	sec = math.abs(sec)
	return ('%s%02d:%02d'):format(sign, math.floor(sec / 60), sec % 60)
end

local function render_status()
	local win = status_win

	if not client then
		win:cursor(0, 0)
		win:attr(curs.A_BOLD, 0)
		win:put('Disconnected')
		win:clrtoeol()
		win:refresh()
		return
	end

	local pct = (props.duration or 0) ~= 0
			and (props['time-pos'] or 0) / props.duration
		or 0

	win:cursor(0, 0)
	win:attr(curs.A_BOLD, 0)
	if props.pause then
		win:put('(Paused) ')
	end
	if props.mute then
		win:put('(Muted) ')
	end

	win:attr(curs.A_NORMAL, 0)
	win:putf(
		'[%d/%d] %s / %s (%2d%%) ',
		props['playlist-pos-1'],
		props['playlist-count'],
		format_time(props['time-pos'] or 0),
		format_time(props.duration or 0),
		100 * pct
	)
	if props.speed ~= 1 then
		win:putf('x%.2f ', props.speed)
	end
	win:putf('Volume: %d%% ', props.volume)

	local left, left_space, indicator, right_space, right =
		props['term-osd-bar-chars']:match('^(.)(.)(.)(.)(.)$')
	local x0, x1 = win:x() + 1, win:cols() - 1
	local w = x1 - x0
	local sp0 = math.floor(w * pct)
	local sp1 = w - 1 - sp0
	win:put(left)
	win:put(left_space:rep(sp0))
	win:put(indicator)
	win:put(right_space:rep(sp1))
	win:put(right)

	win:refresh()
end

local function render(full)
	if shellout then
		return
	end

	if full then
		playlist_win:move(0, 0)
		playlist_win:resize(curs.LINES - 1, curs.COLS)

		status_win:move(curs.LINES - 1, 0)
		status_win:resize(1, curs.COLS)

		render_playlist()
	end
	render_status()

	curs.doupdate()
end

local function set_prop(name, data)
	if props[name] ~= data then
		props[name] = data
		render(name == 'playlist' or name == 'playlist-pos-1')
	end
end

local function mpv_keyname(key)
	if key == '^[' then
		return 'ESC'
	elseif key == '^I' then
		return 'TAB'
	elseif key == 'KEY_DC' then
		return 'DEL'
	elseif key == 'KEY_SDC' then
		return 'Shift+DEL'
	elseif key == 'KEY_IC' then
		return 'INSERT'
	end

	local x = key:match('^^([A-Z])$')
	if x then
		return 'Ctrl+' .. x:lower()
	end

	local x = key:match('KEY_([A-Z]+)')
	if x then
		return x
	end

	return key
end

local function enter_shell()
	shellout = true
	stdin:stop()
	sigwinch:stop()
	curs.endwin()
end

local function enter_program()
	shellout = false
	stdin:start('r', function(err)
		if err then
			stdin:close()
			return
		end

		local c = status_win:getch()
		local key = ffi.string(curs.keyname(c))
		local key = mpv_keyname(key)

		if client then
			client:request({
				'set_property',
				'user-data/mpt/last-activity',
				os.time(),
			})
			client:request({ 'keypress', key })
		end
	end)
	sigwinch:start('sigwinch', function()
		curs.endwin()
		curs.doupdate()
		render(true)
	end)
	render(true)
end

local function select_playlist()
	enter_shell()

	local stdin = uv.new_pipe()
	local stdout = uv.new_pipe()
	local reply = ''

	local process
	process = uv.spawn('fzr', {
		args = { '--read0', '--print-index', '--reverse' },
		stdio = { stdin, stdout, 2 },
	}, function(code, signal)
		process:close()
		enter_program()

		if code ~= 0 then
			return
		end

		local index = tonumber(reply:match('^%d+'))
		if client then
			client:request({ 'playlist-play-index', index })
		end
	end)

	local buf = require('string.buffer').new()
	for _, entry in ipairs(props.playlist) do
		buf:put(entry.filename, '\0')
	end
	stdin:write(buf:tostring())
	stdin:shutdown(function()
		stdin:close()
	end)

	stdout:read_start(function(err, data)
		if data then
			reply = reply .. data
		else
			stdout:close()
		end
	end)
end

local function edit(s, line, callback)
	tmpname = tmpname or os.tmpname()

	local f = assert(io.open(tmpname, 'w'))
	assert(f:write(s))
	assert(f:close())

	enter_shell()

	local process
	process = uv.spawn(os.getenv('EDITOR') or 'vim', {
		args = { ('+%d'):format(line), '--', tmpname },
		stdio = { 0, 1, 2 },
		cwd = props['working-directory'],
	}, function(code)
		process:close()
		enter_program()

		if code ~= 0 then
			callback(nil)
			return
		end

		local f = assert(io.open(tmpname))
		local s = f:read('*a')
		assert(f:close())

		callback(s)
	end)
end

local function edit_playlist()
	local buf = require('string.buffer').new()

	local refs = {}
	local current_id = (props.playlist[props['playlist-pos-1']] or {}).id

	for _, entry in ipairs(props.playlist) do
		assert(not entry.filename:find('\n', 1, true))
		buf:put(entry.filename, '\n')
		refs[entry.filename] = { id = entry.id }
	end

	edit(buf:tostring(), props['playlist-pos-1'], function(s)
		if not s then
			return
		end

		local t = {}
		local current_removed = true

		for filename in s:gmatch('[^\n]+') do
			local x = refs[filename] or { filename = filename }
			if x.id == current_id then
				current_removed = false
			end
			table.insert(t, x)
		end

		if current_removed and t[1] then
			t[1].current = true
		end

		client:request({ 'set_property', 'playlist', t })
		client:request({ 'script-message', 'playlist-changed' })
	end)
end

local function edit_properties()
	local function is_blacklisted(name)
		return name:find('%-list$')
			or name:find('%-info$')
			or name:find('%-state$')
			or name:find('%-params$')
			or name:find('^mpv%-')
			or name:find('^vo%-')
			or name == 'options'
			or name == 'file-local-options'
			or name == 'input-bindings'
			or name == 'playlist'
	end

	local function get_all_properties(callback)
		client:request({ 'get_property', 'property-list' }, function(reply)
			local t = {}
			local k = 0

			for _, name in ipairs(reply.data) do
				if not is_blacklisted(name) then
					k = k + 1

					client:request({ 'get_property_string', name }, function(reply)
						table.insert(t, name)
						t[name] = reply.data == json.null and '' or reply.data

						k = k - 1
						if k == 0 then
							callback(t)
						end
					end)
				end
			end
		end)
	end

	get_all_properties(function(t)
		local buf = require('string.buffer').new()

		for _, name in ipairs(t) do
			buf:put(name, '=', t[name], '\n')
		end

		edit(buf:tostring(), 1, function(s)
			if not s then
				return
			end

			for name, value in s:gmatch('([a-z0-9-]+)=([^\n]*)') do
				if t[name] ~= value then
					client:request({ 'set_property_string', name, value })
				end
			end
		end)
	end)
end

local function set_client(client_)
	client = client_
	render(false)
	playlist_timer:stop()

	if not client then
		return
	end

	local playlist_changed = false

	local function update_playlist()
		if playlist_changed then
			playlist_changed = false
			client:request({ 'get_property', 'playlist' }, function(reply)
				set_prop('playlist', reply.data)
			end)
		else
			playlist_timer:stop()
		end
	end

	local function dirty_playlist()
		playlist_changed = true
		if not playlist_timer:is_active() then
			playlist_timer:start(0, 100, update_playlist)
		end
	end

	client:on('property-change', function(event)
		local name = event.name
		local data = event.data

		if name == 'playlist-count' then
			dirty_playlist()
		end

		if name == 'time-pos' and data then
			data = math.floor(data)
		end

		set_prop(name, data)
	end)

	client:on('client-message', function(event)
		local args = event.args
		if args[1] == 'playlist-changed' then
			dirty_playlist()
		elseif args[1] == 'mpt' and args[2] == 'edit-playlist' then
			edit_playlist()
		elseif args[1] == 'mpt' and args[2] == 'edit-properties' then
			edit_properties()
		elseif args[1] == 'mpt' and args[2] == 'select-playlist' then
			select_playlist()
		end
	end)

	for i, name in ipairs({
		'duration',
		'mute',
		'pause',
		'playlist-count',
		'playlist-pos-1',
		'speed',
		'term-osd-bar-chars',
		'time-pos',
		'volume',
		'working-directory',
	}) do
		client:request({ 'observe_property', i, name })
	end
end

local function choose_best_client(clients, callback)
	if #clients == 0 then
		return callback()
	end

	local best
	local best_pause

	local n = #clients
	local function step()
		n = n - 1
		if n == 0 then
			for _, client in ipairs(clients) do
				if client ~= best then
					client:close()
				end
			end
			return callback(best)
		end
	end

	for _, client in ipairs(clients) do
		client:connect(function(err)
			if err then
				return step()
			end
			client:request({ 'get_property', 'pause' }, function(reply)
				local pause = reply.data
				if not best or (best_pause and not pause) then
					best, best_pause = client, pause
				end
				return step()
			end)
		end)
	end
end

do
	local clients = {}
	for _, path in ipairs(arg) do
		table.insert(clients, Client:new(path))
	end
	choose_best_client(clients, function(client)
		if client then
			set_client(client)
		end
	end)
end

enter_program()
uv.run()
enter_shell()

if tmpname then
	os.remove(tmpname)
end
