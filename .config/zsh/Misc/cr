local opt_unsafe opt_profile=() opt_downloads=() opt_readonly_paths=()
zparseopts -D -F -K -- \
	u=opt_unsafe \
	p:=opt_profile \
	d:=opt_downloads \
	r+:=opt_readonly_paths \
|| return 1

local profile_path=${opt_profile[-1]:-.}
local local_state_path="$profile_path/Local State"

ulimit -u 2048

if [[ ! -e "$local_state_path" ]]; then
	cat <<<$local_state >$local_state_path
fi

local extra_args=()
local flag f
for flag f in $opt_readonly_paths; do
	extra_args+=(--ro-bind "$f" "/home/user/${f:t}")
done

oom_adj 1000 bwrap \
	--new-session \
	--as-pid-1 \
	--unshare-all \
	--share-net \
	--hostname hostname \
	--clearenv \
	--setenv XDG_RUNTIME_DIR /priv \
	--setenv HOME /home/user \
	--setenv DISPLAY "${DISPLAY?}" \
	--setenv PATH /usr/bin \
	--setenv TZ "${TZ?}" \
	--dev /dev \
	--dev-bind /dev/snd{,} \
	--dev-bind /dev/dri{,} \
	--dev-bind /dev/video0{,} \
	--dev-bind /dev/video1{,} \
	--proc /proc \
	--ro-bind /sys{,} \
	--ro-bind /usr{,} \
	--ro-bind /etc/hosts{,} \
	--ro-bind /etc/fonts{,} \
	--ro-bind /etc/group{,} \
	--ro-bind /etc/resolv.conf{,} \
	--ro-bind /lib{,} \
	--ro-bind /lib64{,} \
	--tmpfs /priv \
	--ro-bind-data 4 /usr/lib/chromium/initial_preferences \
	4<<<$initial_preferences \
	--ro-bind {~,/home/user}/.config/fontconfig \
	--bind /tmp{,} \
	--bind "${opt_downloads[-1]:-/tmp}" /home/user/Downloads \
	--bind "$profile_path" /home/user/chromium \
	--chdir /home/user/Downloads \
	$extra_args \
	chromium \
	--unsafely-disable-devtools-self-xss-warnings \
	--user-data-dir=/home/user/chromium \
	${opt_unsafe:+--disable-web-security} \
	&!
